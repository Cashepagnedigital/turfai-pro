def scrape_quinte_du_jour() -> dict | None:
    """
    Tente de scraper le Quinté+ du jour depuis plusieurs sources.
    Retourne les données structurées ou None si échec.
    """
    log.info("Tentative scraping API PMU officielle...")
    data = scraper_api_pmu()

    if not data or len(data.get("partants", [])) < 5:
        log.warning("API PMU insuffisante, tentative Geny...")
        data = scraper_geny()

    if not data or len(data.get("partants", [])) < 5:
        log.error("Toutes les sources ont échoué.")
        return None

    # Enrichir avec les cotes live
    data = enrichir_cotes_live(data)

    # Ajouter consensus presse
    data["consensus_presse"] = generer_consensus_presse(len(data["partants"]))

    log.info(f"✅ Scraping réussi via {data['source']} — {len(data['partants'])} partants")
    return data
