# ── Utilitaires ──────────────────────────────────────────

def get_page(url: str, timeout: int = 15) -> BeautifulSoup | None:
    """Récupère une page HTML et retourne un objet BeautifulSoup."""
    try:
        resp = SESSION.get(url, timeout=timeout)
        resp.raise_for_status()
        return BeautifulSoup(resp.text, "html.parser")
    except Exception as e:
        log.warning(f"Erreur fetch {url}: {e}")
        return None


def get_json(url: str, timeout: int = 15) -> dict | None:
    """Récupère une API JSON."""
    try:
        resp = SESSION.get(url, timeout=timeout)
        resp.raise_for_status()
        return resp.json()
    except Exception as e:
        log.warning(f"Erreur JSON {url}: {e}")
        return None


# ── Source principale : API PMU officielle ───────────────

def scraper_api_pmu() -> dict | None:
    """
    Utilise l'API PMU pour récupérer le programme du jour.
    Endpoint public non-authentifié.
    """
    today = date.today().strftime("%d%m%Y")
    url = f"https://online.turfinfo.api.pmu.fr/rest/client/61/programme/{today}?meteo=true&grands-prix=true"

    data = get_json(url)
    if not data:
        return None

    try:
        reunions = data.get("programme", {}).get("reunions", [])
        for reunion in reunions:
            courses = reunion.get("courses", [])
            for course in courses:
                # Chercher la course Quinté+
                paris = course.get("paris", [])
                paris_noms = [p.get("libelle", "").upper() for p in paris]
                if any("QUINT" in p for p in paris_noms):
                    return extraire_course_pmu(reunion, course)
    except Exception as e:
        log.warning(f"Erreur parsing API PMU: {e}")

    return None


def extraire_course_pmu(reunion: dict, course: dict) -> dict:
    """Extrait les données structurées d'une course PMU."""
    partants_raw = course.get("partants", [])
    partants = []

    for p in partants_raw:
        if p.get("nonPartant", False):
            continue

        # Musique
        musique = p.get("dernierRapportDirect", {})
        musique_str = p.get("gainsParticipant", {}).get("totalGainsCarriere", "")

        # Extraction musique depuis historiqueParticipant
        hist = p.get("historiqueParticipant", [])
        musique_tokens = []
        for h in hist[:7]:
            place = h.get("ordreArrivee")
            if place:
                musique_tokens.append(str(place))
            else:
                musique_tokens.append("(25)")
        musique_affichage = " ".join(musique_tokens) if musique_tokens else "(25) (25) (25)"

        partant = {
            "num": p.get("numPmu", 0),
            "nom": p.get("nom", "INCONNU").upper(),
            "jockey": p.get("driver", p.get("jockey", {})).__class__.__name__ != "dict"
                      and p.get("driver", p.get("jockey", "N/A"))
                      or p.get("driver", {}).get("nom", p.get("jockey", {}).get("nom", "N/A")),
            "entraineur": (p.get("entraineur") or {}).get("nom", "N/A"),
            "poids": p.get("poidsKg", 0),
            "corde": p.get("placeCorde", 0),
            "musique": musique_affichage,
            "age": p.get("age", 0),
            "cote": p.get("dernierRapportDirect", {}).get("rapport", 0) or 10.0,
            "sexe": p.get("sexe", "H"),
        }

        # Normaliser la cote
        try:
            partant["cote"] = float(partant["cote"])
            if partant["cote"] < 1.1:
                partant["cote"] = 5.0
        except:
            partant["cote"] = 10.0

        partants.append(partant)

    # Trier par numéro
    partants.sort(key=lambda x: x["num"])

    # Infos course
    num_r = reunion.get("numOfficiel", 1)
    num_c = course.get("numOrdre", 1)
    hippodrome = reunion.get("hippodrome", {}).get("libelleLong", "Hippodrome")
    nom_course = course.get("libelle", "PRIX DU JOUR").upper()

    # Heure départ
    ts = course.get("heureDepart", 0)
    if ts:
        h = datetime.fromtimestamp(ts / 1000)
        heure = h.strftime("%Hh%M")
    else:
        heure = "15h00"

    return {
        "nom": nom_course,
        "ref": f"R{num_r}C{num_c}",
        "lieu": hippodrome,
        "date": date.today().strftime("%d/%m/%Y"),
        "date_full": datetime.now().strftime("%A %d %B %Y").capitalize(),
        "distance": f"{course.get('distance', 2400)}m",
        "discipline": course.get("discipline", "PLAT").capitalize(),
        "allocation": course.get("montantPrix", 50000),
        "heure": heure,
        "terrain": reunion.get("meteo", {}).get("etatPiste", "Bon"),
        "penetrometre": reunion.get("meteo", {}).get("penetrometre", 0),
        "partants": partants,
        "source": "API PMU officielle",
    }


# ── Source de secours : Geny.com ─────────────────────────

def scraper_geny() -> dict | None:
    """Scrape geny.com pour trouver la course Quinté+ du jour."""
    today = date.today()
    url = f"https://www.geny.com/reunions-courses-pmu?date={today.strftime('%Y-%m-%d')}"
    soup = get_page(url)
    if not soup:
        return None

    try:
        # Chercher les liens de course avec "quinte" ou "quinté"
        links = soup.find_all("a", href=True)
        quinte_url = None
        for link in links:
            href = link.get("href", "")
            text = link.get_text().lower()
            if "quint" in text or "quint" in href.lower():
                quinte_url = "https://www.geny.com" + href if href.startswith("/") else href
                break

        if not quinte_url:
            # Fallback : chercher la 3ème course de la 1ère réunion
            log.warning("Quinté+ non trouvé sur Geny, tentative fallback...")
            return None

        log.info(f"URL Quinté trouvée sur Geny: {quinte_url}")
        return scraper_geny_partants(quinte_url)

    except Exception as e:
        log.warning(f"Erreur Geny: {e}")
        return None


def scraper_geny_partants(url: str) -> dict | None:
    """Scrape la page partants d'une course Geny."""
    soup = get_page(url)
    if not soup:
        return None

    try:
        partants = []
        # Trouver le tableau des partants
        table = soup.find("table", class_=re.compile("partants|chevaux|horses"))
        if not table:
            table = soup.find("table")

        if table:
            rows = table.find_all("tr")[1:]  # skip header
            for i, row in enumerate(rows, 1):
                cols = row.find_all(["td", "th"])
                if len(cols) < 3:
                    continue
                partant = {
                    "num": i,
                    "nom": cols[1].get_text(strip=True).upper() if len(cols) > 1 else f"CHEVAL_{i}",
                    "jockey": cols[2].get_text(strip=True) if len(cols) > 2 else "N/A",
                    "entraineur": cols[3].get_text(strip=True) if len(cols) > 3 else "N/A",
                    "poids": 58,
                    "corde": i,
                    "musique": "(25) (25) (25)",
                    "age": 4,
                    "cote": float(re.search(r'\d+[\.,]\d+', cols[-1].get_text(strip=True) or "10").group().replace(",", ".")) if re.search(r'\d+[\.,]\d+', cols[-1].get_text(strip=True) or "") else 10.0,
                    "sexe": "H",
                }
                partants.append(partant)

        if not partants:
            return None

        # Infos de la page
        title = soup.find("h1")
        nom = title.get_text(strip=True).upper() if title else "QUINTÉ DU JOUR"

        return {
            "nom": nom,
            "ref": "R1C3",
            "lieu": "Hippodrome",
            "date": date.today().strftime("%d/%m/%Y"),
            "date_full": datetime.now().strftime("%A %d %B %Y").capitalize(),
            "distance": "2400m",
            "discipline": "Plat",
            "allocation": 50000,
            "heure": "15h00",
            "terrain": "Bon",
            "penetrometre": 0,
            "partants": partants,
            "source": "Geny.com",
        }

    except Exception as e:
        log.warning(f"Erreur parsing Geny partants: {e}")
        return None


# ── Récupération cotes PMU live ──────────────────────────

def enrichir_cotes_live(course_data: dict) -> dict:
    """Met à jour les cotes avec les valeurs PMU temps réel."""
    today = date.today().strftime("%d%m%Y")
    ref = course_data.get("ref", "R1C3")
    r_num = ref.replace("R", "").split("C")[0]
    c_num = ref.split("C")[-1] if "C" in ref else "3"

    url = (
        f"https://online.turfinfo.api.pmu.fr/rest/client/61/"
        f"programme/{today}/R{r_num}/C{c_num}/rapports-definitifs"
    )

    data = get_json(url)
    if not data:
        return course_data

    try:
        rapports = data.get("rapports", [])
        cotes_map = {}
        for r in rapports:
            if r.get("typePari") == "E_SIMPLE_GAGNANT":
                for cheval in r.get("combinaisons", []):
                    num = cheval.get("numCheval")
                    rapport = cheval.get("rapport", 0)
                    if num and rapport:
                        cotes_map[num] = float(rapport)

        for p in course_data["partants"]:
            if p["num"] in cotes_map:
                p["cote"] = cotes_map[p["num"]]

        log.info(f"✅ {len(cotes_map)} cotes live récupérées")
    except Exception as e:
        log.warning(f"Erreur cotes live: {e}")

    return course_data


# ── Récupération consensus presse ────────────────────────

SOURCES_PRESSE = [
    ("Equidia",    "https://www.equidia.fr"),
    ("Turfoo",     "https://www.turfoo.fr"),
    ("Zone Turf",  "https://www.zone-turf.fr"),
    ("Canal Turf", "https://www.canalturf.com"),
    ("Turfomania", "https://www.turfomania.fr"),
    ("ZEturf",     "https://www.zeturf.fr"),
]

def generer_consensus_presse(nb_partants: int) -> list[dict]:
    """
    Génère un consensus presse simulé cohérent.
    Dans la version complète, scrape les vrais pronostics.
    """
    import random
    random.seed(datetime.now().date().toordinal())  # Reproductible sur la journée

    top_nums = list(range(1, min(nb_partants + 1, 17)))
    random.shuffle(top_nums)
    base_nums = top_nums[:3]

    consensus = []
    for source, _ in SOURCES_PRESSE:
        pronostic = base_nums[:2].copy()
        extras = [n for n in top_nums if n not in pronostic]
        pronostic += random.sample(extras, min(6, len(extras)))
        consensus.append({
            "source": source,
            "nums": pronostic[:8],
            "base": pronostic[:2],
        })

    return consensus


