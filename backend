"""
TurfAI Pro — GitHub Updater
Met à jour index.html sur GitHub via l'API REST
Vercel détecte le changement et redéploie automatiquement
"""

import os
import base64
import logging
import requests

log = logging.getLogger(__name__)

# ── Config (depuis variables d'environnement Railway) ────
GITHUB_TOKEN  = os.environ.get("GITHUB_TOKEN", "")    # Token GitHub Personal Access
GITHUB_OWNER  = os.environ.get("GITHUB_OWNER", "")    # Ton username GitHub
GITHUB_REPO   = os.environ.get("GITHUB_REPO", "turfai-pro")
GITHUB_BRANCH = os.environ.get("GITHUB_BRANCH", "main")
FILE_PATH     = "index.html"

HEADERS = {
    "Authorization": f"Bearer {GITHUB_TOKEN}",
    "Accept": "application/vnd.github+json",
    "X-GitHub-Api-Version": "2022-11-28",
    "Content-Type": "application/json",
}
BASE_URL = f"https://api.github.com/repos/{GITHUB_OWNER}/{GITHUB_REPO}"


def get_file_sha() -> str | None:
    """Récupère le SHA du fichier index.html actuel (nécessaire pour le mettre à jour)."""
    url = f"{BASE_URL}/contents/{FILE_PATH}?ref={GITHUB_BRANCH}"
    try:
        resp = requests.get(url, headers=HEADERS, timeout=15)
        if resp.status_code == 200:
            return resp.json().get("sha")
        elif resp.status_code == 404:
            log.info("Fichier index.html inexistant — sera créé")
            return None
        else:
            log.error(f"Erreur get SHA: {resp.status_code} — {resp.text[:200]}")
            return None
    except Exception as e:
        log.error(f"Exception get SHA: {e}")
        return None


def pousser_sur_github(html_content: str, commit_message: str) -> bool:
    """
    Met à jour ou crée index.html sur GitHub.
    Retourne True si succès, False sinon.
    """
    if not GITHUB_TOKEN or not GITHUB_OWNER:
        log.error("❌ GITHUB_TOKEN ou GITHUB_OWNER non configurés")
        return False

    # Encoder le contenu en base64
    content_b64 = base64.b64encode(html_content.encode("utf-8")).decode("utf-8")

    # Récupérer le SHA existant
    sha = get_file_sha()

    # Construire le payload
    payload = {
        "message": commit_message,
        "content": content_b64,
        "branch":  GITHUB_BRANCH,
    }
    if sha:
        payload["sha"] = sha  # Nécessaire pour une mise à jour

    # Envoyer la requête
    url = f"{BASE_URL}/contents/{FILE_PATH}"
    try:
        resp = requests.put(url, headers=HEADERS, json=payload, timeout=30)

        if resp.status_code in (200, 201):
            commit_url = resp.json().get("commit", {}).get("html_url", "")
            log.info(f"✅ GitHub mis à jour : {commit_url}")
            return True
        else:
            log.error(f"❌ Erreur GitHub PUT: {resp.status_code}")
            log.error(f"   Détail: {resp.text[:500]}")
            return False

    except Exception as e:
        log.error(f"Exception GitHub push: {e}")
        return False


def verifier_connexion() -> bool:
    """Vérifie que les credentials GitHub sont valides."""
    if not GITHUB_TOKEN:
        log.error("GITHUB_TOKEN non défini")
        return False

    try:
        resp = requests.get(
            "https://api.github.com/user",
            headers=HEADERS,
            timeout=10
        )
        if resp.status_code == 200:
            user = resp.json().get("login", "inconnu")
            log.info(f"✅ GitHub connecté en tant que : {user}")
            return True
        else:
            log.error(f"❌ Token GitHub invalide : {resp.status_code}")
            return False
    except Exception as e:
        log.error(f"Exception vérification GitHub: {e}")
        return False
"""
TurfAI Pro — Notifier WhatsApp
Envoie les notifications via CallMeBot (gratuit, pas d'API payante)
"""

import os
import logging
import requests
from urllib.parse import quote

log = logging.getLogger(__name__)

# ── Config (variables d'environnement Railway) ───────────
WHATSAPP_PHONE  = os.environ.get("WHATSAPP_PHONE", "")    # ex: 22797123456
CALLMEBOT_KEY   = os.environ.get("CALLMEBOT_KEY", "")     # Clé API CallMeBot


def envoyer_whatsapp(message: str) -> bool:
    """
    Envoie un message WhatsApp via CallMeBot.
    Gratuit, limite ~200 messages/jour.

    Setup requis : envoyer "I allow callmebot to send me messages" au
    numéro WhatsApp +34 644 58 52 72 pour obtenir la clé API.
    """
    if not WHATSAPP_PHONE or not CALLMEBOT_KEY:
        log.warning("WhatsApp non configuré (WHATSAPP_PHONE ou CALLMEBOT_KEY manquant)")
        return False

    url = (
        f"https://api.callmebot.com/whatsapp.php"
        f"?phone={WHATSAPP_PHONE}"
        f"&text={quote(message)}"
        f"&apikey={CALLMEBOT_KEY}"
    )

    try:
        resp = requests.get(url, timeout=15)
        if resp.status_code == 200 and "Message queued" in resp.text:
            log.info(f"✅ WhatsApp envoyé à {WHATSAPP_PHONE}")
            return True
        else:
            log.warning(f"WhatsApp status {resp.status_code}: {resp.text[:100]}")
            return False
    except Exception as e:
        log.warning(f"Erreur envoi WhatsApp: {e}")
        return False
