def parser_musique(musique: str) -> list[int]:
    """
    Convertit la musique en liste de places numériques.
    Ex: "1p 2p (25) 3p" → [1, 2, 25, 3]
    """
    tokens = musique.upper().split()
    places = []
    for t in tokens[:8]:
        t = t.replace("P", "").replace("H", "").replace("A", "")
        t = t.replace("(", "").replace(")", "").strip()
        if t in ("DA", "DM", "TH", "AH", "TA", "0", "NP", "25"):
            places.append(25)
        else:
            try:
                n = int(t)
                places.append(min(n, 25))
            except:
                places.append(15)
    return places if places else [15, 15, 15]


def score_forme(musique: str) -> float:
    """
    Score de forme basé sur les dernières performances.
    Pondère les courses récentes plus fortement.
    """
    places = parser_musique(musique)
    if not places:
        return 40.0

    score = 0.0
    poids_totaux = 0.0
    for i, place in enumerate(places[:6]):
        poids = 1.0 / (i + 1)  # Plus récent = plus important
        if place == 1:
            pts = 100
        elif place == 2:
            pts = 85
        elif place == 3:
            pts = 72
        elif place <= 5:
            pts = 60
        elif place <= 8:
            pts = 45
        elif place == 25:
            pts = 10  # Non classé / abandon
        else:
            pts = 30

        score += pts * poids
        poids_totaux += poids

    return round(score / poids_totaux, 1) if poids_totaux > 0 else 40.0


def score_regularite(musique: str) -> float:
    """
    Score de régularité : pénalise les grands écarts de performance.
    Un cheval qui finit toujours 3e est plus régulier que 1e/15e/1e.
    """
    places = parser_musique(musique)
    if len(places) < 2:
        return 50.0

    valides = [p for p in places if p < 20]
    if not valides:
        return 20.0

    moyenne = sum(valides) / len(valides)
    variance = sum((p - moyenne) ** 2 for p in valides) / len(valides)
    ecart_type = math.sqrt(variance)

    # Score inversement proportionnel à l'écart-type
    score = max(0, 100 - ecart_type * 8)

    # Bonus si la place moyenne est bonne
    if moyenne <= 3:
        score = min(100, score * 1.2)
    elif moyenne <= 5:
        score = min(100, score * 1.05)

    return round(score, 1)


def score_jockey(jockey: str) -> float:
    """Score basé sur la réputation du jockey."""
    for nom, sc in JOCKEYS_TOP.items():
        if nom.upper() in jockey.upper() or jockey.upper() in nom.upper():
            return float(sc)
    return 65.0  # Score moyen pour un jockey inconnu


def score_entraineur(entraineur: str) -> float:
    """Score basé sur la réputation de l'entraîneur."""
    for nom, sc in ENTRAINEURS_TOP.items():
        if nom.upper() in entraineur.upper() or entraineur.upper() in nom.upper():
            return float(sc)
    return 60.0


def score_cote(cote: float) -> float:
    """
    Score basé sur la cote PMU.
    Les cotes basses indiquent que le marché pense que le cheval a de bonnes chances.
    Mais ne pas trop favoriser les favoris extrêmes.
    """
    if cote <= 0:
        return 50.0
    prob_implicite = (1 / cote) * 100
    # Plafonner à 80 pour éviter la sur-confiance sur le favori
    return round(min(80.0, prob_implicite * 3.5), 1)


def score_poids(poids: float, nb_partants: int = 16) -> float:
    """Score basé sur le poids porté. Poids léger = avantage."""
    if poids <= 0:
        return 60.0
    # Poids typiques : 53-62 kg pour les handicaps
    score = max(20, 100 - (poids - 53) * 4)
    return round(min(100.0, score), 1)


def calculer_score_composite(partant: dict, nb_partants: int = 16) -> dict:
    """
    Calcule le score IA composite et toutes les métriques pour un partant.
    Retourne le partant enrichi.
    """
    # Calcul des scores individuels
    s_forme     = score_forme(partant.get("musique", "(25) (25)"))
    s_reg       = score_regularite(partant.get("musique", "(25) (25)"))
    s_jockey    = score_jockey(partant.get("jockey", ""))
    s_entr      = score_entraineur(partant.get("entraineur", ""))
    s_cote      = score_cote(partant.get("cote", 10.0))
    s_poids     = score_poids(partant.get("poids", 58), nb_partants)

    # Score composite pondéré
    score_ia = (
        s_forme     * POIDS["forme"]      +
        s_reg       * POIDS["regularite"] +
        s_jockey    * POIDS["jockey"]     +
        s_entr      * POIDS["entraineur"] +
        s_cote      * POIDS["cote"]       +
        s_poids     * POIDS["poids"]
    )

    score_ia = round(min(99.9, max(5.0, score_ia)), 1)

    return {
        **partant,
        "score_ia": score_ia,
        "scores_detail": {
            "forme": s_forme,
            "regularite": s_reg,
            "jockey": s_jockey,
            "entraineur": s_entr,
            "cote": s_cote,
            "poids": s_poids,
        }
    }


def normaliser_probabilites(partants: list[dict]) -> list[dict]:
    """
    Convertit les scores IA en probabilités de victoire normalisées (somme = 100%).
    """
    total = sum(p["score_ia"] for p in partants)
    for p in partants:
        p["prob_ia"] = round((p["score_ia"] / total) * 100, 1)
        # Probabilité implicite de la cote
        p["prob_cote"] = round((1 / p["cote"]) * 100, 1) if p["cote"] > 0 else 10.0
        # Edge Value Bet
        p["edge"] = round(p["prob_ia"] - p["prob_cote"], 1)
        p["is_vb"] = p["edge"] > 0
    return partants


def generer_grilles(partants_tries: list[dict]) -> dict:
    """
    Génère les grilles de paris optimales basées sur le classement IA.
    """
    top5 = [p["num"] for p in partants_tries[:5]]
    top4 = top5[:4]
    top3 = top5[:3]
    top2 = top5[:2]

    # Value bets pour alternatives
    vbs = [p["num"] for p in partants_tries if p["is_vb"]]

    # Grille Quinté+ élargie (8 meilleurs)
    top8 = [p["num"] for p in partants_tries[:8]]
    bases = top2
    complements = [p["num"] for p in partants_tries[2:5]]
    jokers = [p["num"] for p in partants_tries[5:8]]

    # Alternatives
    alt1 = top4 + [partants_tries[5]["num"]] if len(partants_tries) > 5 else top5
    alt2 = top3 + [partants_tries[4]["num"], partants_tries[5]["num"]] if len(partants_tries) > 5 else top5

    return {
        "couple":   top2,
        "tierce":   top3,
        "quarte":   top4,
        "quinte":   top5,
        "alt1":     alt1,
        "alt2":     alt2,
        "elargi8":  top8,
        "bases":    bases,
        "complements": complements,
        "jokers":   jokers,
        "value_bets": vbs[:5],
    }


def calculer_kelly(partants: list[dict], capital: float = 100.0, kelly_pct: float = 0.25) -> dict:
    """
    Calcule les mises optimales via Kelly Criterion.
    """
    total_prob = sum(p["prob_ia"] for p in partants)
    mises = {}
    for p in partants:
        mise_raw = capital * kelly_pct * (p["prob_ia"] / total_prob)
        mise = max(1.5, round(mise_raw * 2) / 2)  # Arrondi 0.50€, min PMU 1.50€
        mises[p["num"]] = mise
    return mises


def analyser_partants(course_data: dict) -> dict:
    """
    Fonction principale : analyse tous les partants et enrichit les données de course.
    """
    partants = course_data["partants"]
    nb = len(partants)
    log.info(f"Analyse de {nb} partants...")

    # Calcul des scores
    partants = [calculer_score_composite(p, nb) for p in partants]

    # Normalisation probabilités
    partants = normaliser_probabilites(partants)

    # Tri par score IA décroissant
    partants_tries = sorted(partants, key=lambda x: x["score_ia"], reverse=True)

    # Rang IA
    for i, p in enumerate(partants_tries):
        p["rang_ia"] = i + 1

    # Trier aussi par numéro pour le tableau
    partants_par_num = sorted(partants, key=lambda x: x["num"])

    # Favori et best VB
    favori = partants_tries[0]
    vbs_positifs = [p for p in partants_tries if p["is_vb"]]
    best_vb = max(vbs_positifs, key=lambda x: x["edge"]) if vbs_positifs else favori

    # Grilles
    grilles = generer_grilles(partants_tries)

    # Kelly avec 100€ de capital
    mises = calculer_kelly(partants_tries, capital=100.0)

    log.info(f"✅ Favori IA : N°{favori['num']} {favori['nom']} (score {favori['score_ia']})")
    log.info(f"✅ Quinté+ base : {' – '.join(map(str, grilles['quinte']))}")
    log.info(f"✅ Best VB : N°{best_vb['num']} {best_vb['nom']} (edge +{best_vb['edge']:.1f}%)")

    return {
        **course_data,
        "partants":        partants_par_num,
        "partants_tries":  partants_tries,
        "favori":          favori,
        "best_vb":         best_vb,
        "nb_vb":           len(vbs_positifs),
        "grilles":         grilles,
        "mises_kelly":     mises,
        "quinte_base":     grilles["quinte"],
        "total_prob":      sum(p["prob_ia"] for p in partants),
    }

